@model BikeEnergyModel.Models.RideResultsViewModel
@{
    ViewData["Title"] = "Bike Energy Calculator";
    var crrOptions = BikeEnergyModel.Models.BikeInput.CrrOptions;
}

<h1 class="mb-4">Bike Energy Calculator</h1>
<p class="text-muted mb-4">
    Estimates human-supplied energy (kJ) across a configurable set of bikes.
</p>

<form asp-action="Index" method="post" class="mb-5">
    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <label asp-for="Input.TargetSpeedMph" class="form-label"></label>
            <input asp-for="Input.TargetSpeedMph" class="form-control" placeholder="e.g. 15" />
            <span asp-validation-for="Input.TargetSpeedMph" class="text-danger small"></span>
        </div>
        <div class="col-md-4">
            <label asp-for="Input.RiderWeightLbs" class="form-label"></label>
            <input asp-for="Input.RiderWeightLbs" class="form-control" placeholder="e.g. 180" />
            <span asp-validation-for="Input.RiderWeightLbs" class="text-danger small"></span>
        </div>
        <div class="col-md-4">
            <label asp-for="Input.MotorCutoffSpeedMph" class="form-label"></label>
            <input asp-for="Input.MotorCutoffSpeedMph" class="form-control" />
            <span asp-validation-for="Input.MotorCutoffSpeedMph" class="text-danger small"></span>
        </div>
        <div class="col-md-4">
            <label asp-for="Input.MaxMotorAssistWatts" class="form-label"></label>
            <input asp-for="Input.MaxMotorAssistWatts" class="form-control" />
            <span asp-validation-for="Input.MaxMotorAssistWatts" class="text-danger small"></span>
        </div>
        <div class="col-md-4">
            <label asp-for="Input.ElevationGainFeet" class="form-label"></label>
            <input asp-for="Input.ElevationGainFeet" class="form-control" placeholder="e.g. 500" />
            <span asp-validation-for="Input.ElevationGainFeet" class="text-danger small"></span>
        </div>
    </div>

    <h5 class="mb-3">Bikes</h5>
    <table class="table table-sm table-bordered align-middle mb-2" style="max-width: 900px;">
        <thead class="table-light">
            <tr>
                <th>Name</th>
                <th>Weight (lbs)</th>
                <th>Coefficient of Rolling Resistance</th>
                <th>Battery (Wh)</th>
                <th style="width:1%"></th>
            </tr>
        </thead>
        <tbody id="bikes-container">
            @for (int i = 0; i < Model.Input.Bikes.Count; i++)
            {
                var bike = Model.Input.Bikes[i];
                <tr class="bike-row">
                    <td><input name="Input.Bikes[@i].Name" class="form-control form-control-sm" value="@bike.Name" placeholder="Bike name" /></td>
                    <td><input name="Input.Bikes[@i].WeightLbs" class="form-control form-control-sm" value="@bike.WeightLbs" placeholder="20" /></td>
                    <td>
                        <select name="Input.Bikes[@i].RollingResistance" class="form-select form-select-sm crr-select">
                            @foreach (var opt in crrOptions)
                            {
                                <option value="@opt.Value.ToString("0.000", System.Globalization.CultureInfo.InvariantCulture)" selected="@(Math.Abs(bike.RollingResistance - opt.Value) < 1e-9)">@opt.Label (@opt.Value.ToString("0.000"))</option>
                            }
                        </select>
                    </td>
                    <td><input name="Input.Bikes[@i].BatteryCapacityWh" class="form-control form-control-sm" value="@bike.BatteryCapacityWh" placeholder="0" /></td>
                    <td><button type="button" class="btn btn-outline-danger btn-sm remove-bike">&times;</button></td>
                </tr>
            }
        </tbody>
    </table>
    <button type="button" id="add-bike" class="btn btn-outline-secondary btn-sm mb-4">+ Add Bike</button>

    <h5 class="mb-3">Ride Legs</h5>
    <table class="table table-sm table-bordered align-middle mb-2" style="max-width: 600px;">
        <thead class="table-light">
            <tr>
                <th>Distance (mi)</th>
                <th>Wind (mph)</th>
                <th>Direction</th>
                <th style="width:1%"></th>
            </tr>
        </thead>
        <tbody id="legs-container">
            @for (int i = 0; i < Model.Input.Legs.Count; i++)
            {
                <tr class="leg-row">
                    <td><input name="Input.Legs[@i].DistanceMiles" class="form-control form-control-sm" value="@Model.Input.Legs[i].DistanceMiles" placeholder="15" /></td>
                    <td><input name="Input.Legs[@i].WindSpeedMph" class="form-control form-control-sm" value="@Model.Input.Legs[i].WindSpeedMph" placeholder="10" /></td>
                    <td>
                        <select name="Input.Legs[@i].WindDirection" class="form-select form-select-sm">
                            <option value="None" selected="@(Model.Input.Legs[i].WindDirection == "None")">None</option>
                            <option value="Headwind" selected="@(Model.Input.Legs[i].WindDirection == "Headwind")">Headwind</option>
                            <option value="Tailwind" selected="@(Model.Input.Legs[i].WindDirection == "Tailwind")">Tailwind</option>
                            <option value="Crosswind" selected="@(Model.Input.Legs[i].WindDirection == "Crosswind")">Crosswind</option>
                        </select>
                    </td>
                    <td><button type="button" class="btn btn-outline-danger btn-sm remove-leg">&times;</button></td>
                </tr>
            }
        </tbody>
    </table>
    <button type="button" id="add-leg" class="btn btn-outline-secondary btn-sm mb-4">+ Add Leg</button>

    <div>
        <button type="submit" class="btn btn-primary px-4">Calculate</button>
    </div>
</form>

@if (Model.Results is { Count: > 0 })
{
    <h2 class="mb-3">Results</h2>
    @if (Model.TotalRideDistanceMiles.HasValue)
    {
        <p class="text-muted">Total ride distance: <strong>@Model.TotalRideDistanceMiles.Value.ToString("F1") miles</strong></p>
    }
    <div class="table-responsive">
        <table class="table table-bordered align-middle">
            <thead class="table-light">
                <tr>
                    <th>Bike</th>
                    <th class="text-end">Human Energy (kJ)</th>
                    <th class="text-end">Motor Duration</th>
                    <th class="text-end">Battery Remaining</th>
                    <th class="text-end">Optimal Motor</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model.Results)
                {
                    <tr class="@(r.IsRecommended ? "table-success" : "")">
                        <td>
                            @if (r.IsRecommended)
                            {
                                <span class="me-1">&#9733;</span>
                            }
                            <strong>@r.ConfigName</strong>
                            @if (r.IsRecommended)
                            {
                                <span class="badge bg-success ms-2">Recommended</span>
                            }
                        </td>
                        <td class="text-end fw-semibold">@r.HumanEnergyKJ.ToString("F1")</td>
                        <td class="text-end">
                            @if (r.MotorAssistDuration.HasValue)
                            {
                                @($"{(int)r.MotorAssistDuration.Value.TotalHours}:{r.MotorAssistDuration.Value.Minutes:D2}")
                            }
                            else
                            {
                                <span class="text-muted">&mdash;</span>
                            }
                        </td>
                        <td class="text-end">
                            @if (r.BatteryRemainingWh.HasValue)
                            {
                                @($"{r.BatteryRemainingWh.Value:F1} Wh")
                            }
                            else
                            {
                                <span class="text-muted">&mdash;</span>
                            }
                        </td>
                        <td class="text-end">
                            @if (r.OptimalMotorWatts.HasValue)
                            {
                                @($"{r.OptimalMotorWatts.Value:F1} W")
                            }
                            else
                            {
                                <span class="text-muted">&mdash;</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        var crrOptionsHtml = `@Html.Raw(string.Join("", crrOptions.Select(o => $"<option value=\"{o.Value.ToString("0.000", System.Globalization.CultureInfo.InvariantCulture)}\">{o.Label} ({o.Value.ToString("0.000")})</option>")))`;

        var MIN_BIKES = 2;
        var MIN_LEGS = 1;

        function updateRemoveButtons(containerId, rowClass, removeClass, minRows) {
            var rows = document.querySelectorAll('#' + containerId + ' .' + rowClass);
            var disabled = rows.length <= minRows;
            rows.forEach(function (row) {
                var btn = row.querySelector('.' + removeClass);
                if (btn) btn.disabled = disabled;
            });
        }

        function reindex(containerId, rowClass, fieldPrefix) {
            document.querySelectorAll('#' + containerId + ' .' + rowClass).forEach(function (row, idx) {
                row.querySelectorAll('input, select').forEach(function (el) {
                    el.name = el.name.replace(new RegExp(fieldPrefix + '\\[\\d+\\]'), fieldPrefix + '[' + idx + ']');
                });
            });
        }

        // Bikes
        document.getElementById('add-bike').addEventListener('click', function () {
            var container = document.getElementById('bikes-container');
            var index = container.querySelectorAll('.bike-row').length;
            var html = `<tr class="bike-row">
                <td><input name="Input.Bikes[${index}].Name" class="form-control form-control-sm" placeholder="Bike name" /></td>
                <td><input name="Input.Bikes[${index}].WeightLbs" class="form-control form-control-sm" placeholder="20" /></td>
                <td><select name="Input.Bikes[${index}].RollingResistance" class="form-select form-select-sm crr-select">${crrOptionsHtml}</select></td>
                <td><input name="Input.Bikes[${index}].BatteryCapacityWh" class="form-control form-control-sm" placeholder="0" /></td>
                <td><button type="button" class="btn btn-outline-danger btn-sm remove-bike">&times;</button></td>
            </tr>`;
            container.insertAdjacentHTML('beforeend', html);
            updateRemoveButtons('bikes-container', 'bike-row', 'remove-bike', MIN_BIKES);
        });

        document.getElementById('bikes-container').addEventListener('click', function (e) {
            if (e.target.classList.contains('remove-bike')) {
                var rows = document.querySelectorAll('#bikes-container .bike-row');
                if (rows.length > MIN_BIKES) {
                    e.target.closest('.bike-row').remove();
                    reindex('bikes-container', 'bike-row', 'Input.Bikes');
                    updateRemoveButtons('bikes-container', 'bike-row', 'remove-bike', MIN_BIKES);
                }
            }
        });

        // Legs
        document.getElementById('add-leg').addEventListener('click', function () {
            var container = document.getElementById('legs-container');
            var index = container.querySelectorAll('.leg-row').length;
            var html = `<tr class="leg-row">
                <td><input name="Input.Legs[${index}].DistanceMiles" class="form-control form-control-sm" placeholder="15" /></td>
                <td><input name="Input.Legs[${index}].WindSpeedMph" class="form-control form-control-sm" placeholder="10" /></td>
                <td><select name="Input.Legs[${index}].WindDirection" class="form-select form-select-sm">
                    <option value="None">None</option><option value="Headwind">Headwind</option>
                    <option value="Tailwind">Tailwind</option><option value="Crosswind">Crosswind</option>
                </select></td>
                <td><button type="button" class="btn btn-outline-danger btn-sm remove-leg">&times;</button></td>
            </tr>`;
            container.insertAdjacentHTML('beforeend', html);
            updateRemoveButtons('legs-container', 'leg-row', 'remove-leg', MIN_LEGS);
        });

        document.getElementById('legs-container').addEventListener('click', function (e) {
            if (e.target.classList.contains('remove-leg')) {
                var rows = document.querySelectorAll('#legs-container .leg-row');
                if (rows.length > MIN_LEGS) {
                    e.target.closest('.leg-row').remove();
                    reindex('legs-container', 'leg-row', 'Input.Legs');
                    updateRemoveButtons('legs-container', 'leg-row', 'remove-leg', MIN_LEGS);
                }
            }
        });

        // Initial state
        updateRemoveButtons('bikes-container', 'bike-row', 'remove-bike', MIN_BIKES);
        updateRemoveButtons('legs-container', 'leg-row', 'remove-leg', MIN_LEGS);
    </script>
}
